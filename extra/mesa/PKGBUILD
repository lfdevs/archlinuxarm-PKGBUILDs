pkgbase=mesa
pkgname=(
  mesa
  vulkan-freedreno
)
pkgver=26.1.0
_pkgver=${pkgver/[a-z]/-&}
pkgrel=2
epoch=1
pkgdesc="Open-source OpenGL drivers"
url="https://www.mesa3d.org/"
arch=(aarch64)
license=("MIT AND BSD-3-Clause AND SGI-B-2.0")
makedepends=(
  clang
  directx-headers
